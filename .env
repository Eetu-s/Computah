# Which speech-input path to run. Docker Compose reads this automatically.
#   stt   -> cheap Moonshine STT container (mic + engine)
#   agent -> multimodal LLM container (agent + llama)
# The unselected path's containers are not built or started.
# Override per-command, e.g.:  COMPOSE_PROFILES=agent docker compose up -d

COMPOSE_PROFILES=agent #stt or agent here
